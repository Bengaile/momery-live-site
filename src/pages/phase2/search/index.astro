---
import BaseLayout from '../../../layouts/BaseLayout.astro';
---
<BaseLayout title="Search" description="Search across every story, song, person, and photo in the archive." noindex={true}>
  <section class="pt-10 pb-24 px-6 max-w-2xl mx-auto text-center min-h-[60vh] flex flex-col items-center justify-center">
    <p class="eyebrow block mb-3">Phase 2</p>
    <h1 class="font-serif text-4xl mb-4">Search</h1>
    <p class="opacity-75">Search across every story, song, person, and photo in the archive. Coming in Phase 2 of the MOmery archive.</p>
    <a href="/" class="inline-block mt-8 text-gold underline hover:text-gold-soft">&larr; Back home</a>
  </section>
</BaseLayout>
