---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout
  title="Memories"
  description="Got a few minutes? Answer a handful of questions and add your own MOment to the archive."
>
  <section class="pt-10 pb-20 px-6 max-w-3xl mx-auto bg-forest text-cream text-center">
    <p class="eyebrow block mb-3">Add to the Archive</p>
    <h1 class="font-serif text-4xl md:text-5xl mb-6">Memories</h1>
    <p class="opacity-80 max-w-xl mx-auto mb-10">
      A few questions, a few minutes — that's all it takes to add your own MOment to the
      archive. Answer as many or as few as you'd like. Your answers go straight into the
      MOmery archive — no account or sign-up needed on your end.
    </p>

    <div class="momery-form-wrap">
      <iframe
        src="https://docs.google.com/forms/d/1M6_1RHz6CDTKfyOY_t2yKk7iBt1eZCUznjZGpp4rcxU/viewform?embedded=true"
        width="100%"
        height="1200"
        frameborder="0"
        marginheight="0"
        marginwidth="0"
      >
        Loading…
      </iframe>
    </div>
  </section>
</BaseLayout>

<style>
  .momery-form-wrap {
    max-width: 700px;
    margin: 0 auto;
    border-radius: 8px;
    overflow: hidden;
    background: #fff;
  }
  .momery-form-wrap iframe {
    display: block;
    border: none;
  }
</style>
