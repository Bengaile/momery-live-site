---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import PersonCard from '../../components/PersonCard.astro';

const people = (await getCollection('people')).sort((a, b) => a.data.order - b.data.order);
---
<BaseLayout
  title="People"
  description="Every camp has its characters. Meet the people of MOmery and Deer Camp."
>
  <section class="pt-32 pb-20 px-6 max-w-6xl mx-auto bg-forest text-cream">
    <p class="eyebrow block mb-3">The Cast, For Real</p>
    <h1 class="font-serif text-4xl md:text-5xl mb-10">People</h1>
    <div class="grid sm:grid-cols-2 md:grid-cols-4 gap-5">
      {people.map((person) => (
        <PersonCard
          name={person.data.name}
          role={person.data.role}
          favoriteMemory={person.data.favoriteMemory}
        />
      ))}
    </div>
    <p class="mt-10 text-sm opacity-70">
      New person to add? Drop a new Markdown file in <code>src/content/people/</code> — no other
      changes needed.
    </p>
  </section>
</BaseLayout>
