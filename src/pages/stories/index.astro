---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import StoryRow from '../../components/StoryRow.astro';

const stories = (await getCollection('stories')).filter((s) => !s.data.draft);
---
<BaseLayout
  title="Stories"
  description="Written and spoken memories from Deer Camp, kept the way they were told."
>
  <section class="pt-10 pb-20 px-6 max-w-4xl mx-auto bg-forest text-cream">
    <p class="eyebrow block mb-3">In Their Own Words</p>
    <h1 class="font-serif text-4xl md:text-5xl mb-10">Stories</h1>
    <div class="border-t border-gold/25">
      {stories.map((story) => (
        <StoryRow
          title={story.data.title}
          date={story.data.date}
          summary={story.data.summary}
          href={`/stories/${story.slug}/`}
        />
      ))}
    </div>
  </section>
</BaseLayout>
