---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout
  title="About MOmery"
  description="The story behind MOmery — why the name, what MO stands for, and the mission to preserve the moments that become the memories."
>
  <section class="pt-32 pb-20 px-6 max-w-5xl mx-auto bg-cream-2">
    <p class="eyebrow block mb-3">The Why</p>
    <h1 class="font-serif text-4xl md:text-5xl mb-10">About MOmery</h1>

    <div class="grid md:grid-cols-2 gap-10 items-center">
      <div>
        <p class="opacity-85">
          MOmery began with a little cat named MoMo, a toy she carried, and the realization that
          the smallest moments often become the ones we treasure most.
        </p>
        <blockquote class="font-serif italic text-xl border-l-4 border-gold pl-5 mt-6 max-w-sm">
          To preserve the moments that become the memories.
        </blockquote>
        <p class="mt-6 opacity-85"><strong>Gaile</strong> &mdash; Chief Collector of MOments.</p>
      </div>
      <div class="flex flex-wrap gap-4">
        <div class="border border-gold px-5 py-4 min-w-[150px]">
          <strong class="block font-serif text-gold text-xl">MO</strong>MoMo
        </div>
        <div class="border border-gold px-5 py-4 min-w-[150px]">
          <strong class="block font-serif text-gold text-xl">MO</strong>ment
        </div>
        <div class="border border-gold px-5 py-4 min-w-[150px]">
          <strong class="block font-serif text-gold text-xl">MO</strong>ving through seasons
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
