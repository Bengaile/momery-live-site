---
/**
 * Site navigation.
 * NAV_LINKS is the single source of truth for the primary menu.
 * Add a Phase 2 page? Add one line here — nothing else to touch.
 * `phase: 2` items render with a "Soon" tag until they're ready;
 * flip `enabled: true` when the page is live.
 */
const NAV_LINKS = [
  { href: '/documentary/', label: 'Documentary', phase: 1, enabled: true },
  { href: '/deer-camp/', label: 'Deer Camp', phase: 1, enabled: true },
  { href: '/people/', label: 'People', phase: 1, enabled: true },
  { href: '/pets/', label: 'Camp Pets', phase: 1, enabled: true },
  { href: '/stories/', label: 'Stories', phase: 1, enabled: true },
  { href: '/gallery/', label: 'Gallery', phase: 1, enabled: true },
  { href: '/about/', label: 'About', phase: 1, enabled: true },
  { href: '/contact/', label: 'Share a MOment', phase: 1, enabled: true },
  { href: '/phase2/timeline/', label: 'Timeline', phase: 2, enabled: false },
  { href: '/phase2/map/', label: 'Map', phase: 2, enabled: false },
];
---
<header id="site-header" class="fixed top-0 inset-x-0 z-50 transition-colors duration-300" data-scrolled="false">
  <nav class="max-w-6xl mx-auto flex items-center justify-between px-6 py-4">
    <a href="/" class="font-serif text-2xl text-cream">
      MO<em class="text-gold-soft not-italic">mery</em>
    </a>
    <button
      id="nav-toggle"
      class="md:hidden text-cream text-2xl"
      aria-label="Open menu"
      aria-expanded="false"
      aria-controls="nav-links"
    >&#9776;</button>
    <div id="nav-links" class="hidden md:flex gap-6 text-sm">
      {NAV_LINKS.filter((l) => l.enabled).map((link) => (
        <a href={link.href} class="text-cream-2/85 hover:text-gold-soft transition-colors">
          {link.label}
        </a>
      ))}
    </div>
  </nav>
</header>

<script>
  const header = document.getElementById('site-header');
  const toggleBtn = document.getElementById('nav-toggle');
  const links = document.getElementById('nav-links');

  const onScroll = () => {
    const scrolled = window.scrollY > 40;
    header?.setAttribute('data-scrolled', String(scrolled));
    header?.classList.toggle('bg-forest-deep/95', scrolled);
    header?.classList.toggle('backdrop-blur-sm', scrolled);
    header?.classList.toggle('shadow-lg', scrolled);
  };
  window.addEventListener('scroll', onScroll);
  onScroll();

  toggleBtn?.addEventListener('click', () => {
    const isOpen = links?.classList.toggle('flex');
    links?.classList.toggle('hidden');
    links?.classList.toggle('flex-col');
    links?.classList.toggle('absolute', isOpen);
    links?.classList.toggle('top-full', isOpen);
    links?.classList.toggle('inset-x-0', isOpen);
    links?.classList.toggle('bg-forest-deep', isOpen);
    links?.classList.toggle('p-6', isOpen);
    links?.classList.toggle('gap-4', isOpen);
    toggleBtn.setAttribute('aria-expanded', String(Boolean(isOpen)));
  });
</script>
